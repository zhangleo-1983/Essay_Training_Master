# AUTH_MODE: disabled or api-key.
AUTH_MODE="disabled"

# VITE_API_BASE_URL: Frontend API base URL used by the Vite app.
VITE_API_BASE_URL="http://127.0.0.1:8787/api"

# VITE_API_KEY: Optional frontend API key for local development when AUTH_MODE=api-key.
VITE_API_KEY=""

# AUTH_API_KEYS_JSON:
# Example:
# [{"key":"dev-user-key","userId":"student-1","role":"user"},{"key":"dev-admin-key","userId":"admin","role":"admin"}]
AUTH_API_KEYS_JSON=""

# MODEL_PROVIDER: gemini, openai, deepseek, or openai-compatible.
MODEL_PROVIDER="gemini"

# MODEL_NAME: Generic model name override used by the selected provider.
# For Gemini this can stay empty to use the default below.
MODEL_NAME=""

# AI_API_KEY: Generic API key override for the selected provider.
AI_API_KEY=""

# AI_BASE_URL: Generic OpenAI-compatible base URL override, such as a proxy endpoint.
AI_BASE_URL=""

# GEMINI_API_KEY: Gemini API key when MODEL_PROVIDER=gemini.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: Backend API server port for local development.
PORT="8787"

# HOST: Backend API bind address for local development.
HOST="127.0.0.1"

# GEMINI_MODEL: Optional override for the server-side model.
GEMINI_MODEL="gemini-2.5-flash"

# OPENAI_API_KEY / OPENAI_MODEL / OPENAI_BASE_URL:
# Used when MODEL_PROVIDER=openai.
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# DEEPSEEK_API_KEY / DEEPSEEK_MODEL / DEEPSEEK_BASE_URL:
# Used when MODEL_PROVIDER=deepseek.
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# MODEL_MAX_RETRIES / MODEL_RETRY_BASE_DELAY_MS:
# Retry configuration for upstream model calls.
MODEL_MAX_RETRIES="2"
MODEL_RETRY_BASE_DELAY_MS="300"

# MODEL_PRICING_JSON:
# Optional per-provider/model pricing map used for estimated cost reports.
# Example:
# {"openai:gpt-4.1-mini":{"inputPer1kTokens":0.00015,"outputPer1kTokens":0.0006,"currency":"USD"}}
MODEL_PRICING_JSON=""

# SQLITE_DB_PATH: SQLite database file for persisted writing sessions.
SQLITE_DB_PATH="data/teen-writing-coach.db"

# SESSION_STORAGE_DIR: Optional legacy JSON session directory to import on startup.
SESSION_STORAGE_DIR="data/sessions"

# ALLOWED_ORIGIN: Optional CORS origin for local frontend development.
ALLOWED_ORIGIN="*"

# MESSAGE_RATE_LIMIT_MAX_REQUESTS / MESSAGE_RATE_LIMIT_WINDOW_MS:
# SQLite-backed rate limiting for POST /api/sessions/:sessionId/messages
MESSAGE_RATE_LIMIT_MAX_REQUESTS="20"
MESSAGE_RATE_LIMIT_WINDOW_MS="60000"
